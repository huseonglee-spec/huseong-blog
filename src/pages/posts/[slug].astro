---
import type { GetStaticPaths } from "astro";

import BlogFeed from "../../components/BlogFeed.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../../lib/content";
import { postHref } from "../../lib/posts";

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { activeSlug: post.id },
  }));
}) satisfies GetStaticPaths;

const { activeSlug } = Astro.props;
const posts = await getPublishedPosts();
const activePost = posts.find((post) => post.id === activeSlug);

if (!activePost) {
  return Astro.redirect("/404/");
}

const description = activePost.data.subtitle ?? activePost.data.title;
---

<BaseLayout
  title={`${activePost.data.title} · huseong.com`}
  description={description}
  canonicalPath={postHref(activePost.id)}
  type="article"
>
  <BlogFeed posts={posts} activeSlug={activePost.id} />
</BaseLayout>
