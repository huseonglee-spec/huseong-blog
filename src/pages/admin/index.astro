---
import AdminLayout from "../../layouts/AdminLayout.astro";

const session = Astro.locals.adminSession!;
---

<AdminLayout title="로그인 확인" authenticated csrfToken={session.csrfToken}>
  <section class="admin-panel admin-panel--narrow">
    <h1 class="admin-heading">로그인되었습니다.</h1>
    <p class="admin-help">인증 세션이 정상적으로 작동하고 있습니다.</p>
    <a href="/">블로그로 돌아가기</a>
  </section>
</AdminLayout>
