---
import "@fontsource-variable/noto-serif-kr";

interface Props {
  title: string;
  authenticated?: boolean;
  csrfToken?: string;
}

const { title, authenticated = false, csrfToken = "" } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="theme-color" content="#f2eadb" />
    <title>{title} · huseong.com 관리</title>
  </head>
  <body>
    {authenticated && (
      <header class="admin-header">
        <a class="admin-brand" href="/admin/">huseong.com 관리</a>
        <nav aria-label="관리 메뉴">
          <a href="/admin/posts/new/">새 글</a>
          <a href="/" target="_blank" rel="noreferrer">사이트 보기</a>
          <form action="/api/admin/logout/" method="post">
            <input type="hidden" name="csrfToken" value={csrfToken} />
            <button type="submit">로그아웃</button>
          </form>
        </nav>
      </header>
    )}
    <main class:list={["admin-main", { "admin-main--login": !authenticated }]}>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --paper: #f2eadb;
    --sheet: #fffaf1;
    --ink: #29251f;
    --muted: #756b5f;
    --line: rgba(65, 52, 38, 0.2);
    --accent: #5f4933;
    --danger: #9a3e2e;
    font-family: "Noto Serif KR Variable", "Noto Serif CJK KR", Georgia, serif;
  }

  * { box-sizing: border-box; }
  body {
    min-width: 320px;
    min-height: 100vh;
    margin: 0;
    color: var(--ink);
    background: var(--paper);
    line-height: 1.6;
  }
  a { color: var(--accent); }
  button, input, textarea { font: inherit; }
  button, .button-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    padding: 0.55rem 1rem;
    border: 1px solid var(--ink);
    border-radius: 3px;
    color: #fff;
    background: var(--ink);
    cursor: pointer;
    text-decoration: none;
  }
  button:hover, .button-link:hover { background: var(--accent); }
  button:disabled { cursor: wait; opacity: 0.65; }
  .button-link--secondary {
    color: var(--ink);
    background: transparent;
  }
  .admin-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem clamp(1rem, 4vw, 3rem);
    border-bottom: 1px solid var(--line);
    background: rgba(255, 250, 241, 0.85);
  }
  .admin-brand { color: var(--ink); font-weight: 700; text-decoration: none; }
  .admin-header nav { display: flex; align-items: center; gap: 1rem; }
  .admin-header nav form { margin: 0; }
  .admin-header nav button {
    min-height: auto;
    padding: 0;
    border: 0;
    color: var(--accent);
    background: transparent;
    text-decoration: underline;
  }
  .admin-main {
    width: min(100% - 2rem, 980px);
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 5rem) 0;
  }
  .admin-main--login {
    display: grid;
    min-height: 100vh;
    place-items: center;
    padding-block: 2rem;
  }
  .admin-panel {
    padding: clamp(1.25rem, 4vw, 2.5rem);
    border: 1px solid var(--line);
    border-radius: 4px;
    background: var(--sheet);
  }
  .admin-panel--narrow { width: min(100%, 430px); }
  .admin-heading { margin: 0 0 1.75rem; line-height: 1.3; }
  .admin-heading-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }
  .admin-heading-row h1 { margin: 0; }
  .form-grid { display: grid; gap: 1.15rem; }
  .form-row { display: grid; gap: 0.45rem; }
  .form-row label, .form-label { font-weight: 650; }
  .form-row input, .form-row textarea {
    width: 100%;
    padding: 0.7rem 0.8rem;
    border: 1px solid var(--line);
    border-radius: 3px;
    color: var(--ink);
    background: #fffefb;
  }
  .form-row textarea { min-height: 34rem; resize: vertical; font-family: ui-monospace, monospace; line-height: 1.65; }
  .form-check { display: flex; align-items: center; gap: 0.6rem; }
  .form-check input { width: 1.1rem; height: 1.1rem; }
  .form-actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .form-status { min-height: 1.5em; margin: 0; color: var(--muted); }
  .form-status[data-error="true"], .admin-error { color: var(--danger); }
  .admin-help { color: var(--muted); font-size: 0.92rem; }
  .post-list { margin: 0; padding: 0; list-style: none; }
  .post-list li { border-top: 1px solid var(--line); }
  .post-list li:last-child { border-bottom: 1px solid var(--line); }
  .post-list a {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem 1rem;
    padding: 1rem 0;
    color: inherit;
    text-decoration: none;
  }
  .post-list a:hover .post-list__title { text-decoration: underline; }
  .post-list__meta { color: var(--muted); font-size: 0.85rem; }
  .post-list__badge { color: var(--danger); }
  @media (max-width: 640px) {
    .admin-header, .admin-heading-row { align-items: flex-start; flex-direction: column; }
    .admin-header nav { width: 100%; flex-wrap: wrap; }
    .post-list a { grid-template-columns: 1fr; }
  }
</style>
