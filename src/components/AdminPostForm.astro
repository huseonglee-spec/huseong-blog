---
import type { AdminPost } from "../lib/server/admin-posts";

interface Props {
  csrfToken: string;
  post?: AdminPost;
}

const { csrfToken, post } = Astro.props;
const editing = Boolean(post);
const action = editing
  ? `/api/admin/posts/${encodeURIComponent(post!.slug)}/`
  : "/api/admin/posts/";
---

<form
  class="form-grid"
  action={action}
  method="post"
  data-admin-post-form
  data-initial-published-at={post?.publishedAt.toISOString() ?? ""}
>
  <input type="hidden" name="csrfToken" value={csrfToken} />
  {editing && <input type="hidden" name="revision" value={post!.revision} />}
  {editing && <input type="hidden" name="slug" value={post!.slug} />}

  <div class="form-row">
    <label for="post-slug">Slug</label>
    <input
      id="post-slug"
      name={editing ? undefined : "slug"}
      value={post?.slug ?? ""}
      pattern="[a-z0-9]+(?:-[a-z0-9]+)*"
      maxlength="100"
      autocomplete="off"
      disabled={editing}
      required
    />
    <small class="admin-help">영문 소문자, 숫자, 하이픈만 사용합니다. 생성 후에는 바꿀 수 없습니다.</small>
  </div>

  <div class="form-row">
    <label for="post-title">제목</label>
    <input id="post-title" name="title" value={post?.title ?? ""} maxlength="200" required />
  </div>

  <div class="form-row">
    <label for="post-subtitle">부제</label>
    <input id="post-subtitle" name="subtitle" value={post?.subtitle ?? ""} maxlength="500" />
  </div>

  <div class="form-row">
    <label for="post-published-at">게시 일시</label>
    <input id="post-published-at" name="publishedAtLocal" type="datetime-local" required />
  </div>

  <div class="form-row">
    <label for="post-thumbnail">썸네일 URL</label>
    <input id="post-thumbnail" name="thumbnail" value={post?.thumbnail ?? ""} maxlength="2048" />
  </div>

  <div class="form-row">
    <label for="post-thumbnail-alt">썸네일 설명</label>
    <input id="post-thumbnail-alt" name="thumbnailAlt" value={post?.thumbnailAlt ?? ""} maxlength="500" />
  </div>

  <label class="form-check">
    <input name="draft" type="checkbox" checked={post?.draft ?? true} />
    초안으로 저장해 공개하지 않기
  </label>

  <div class="form-row">
    <label for="post-body">본문 Markdown</label>
    <textarea id="post-body" name="bodyMarkdown" maxlength={512 * 1024} required>{post?.bodyMarkdown ?? ""}</textarea>
  </div>

  <div class="form-actions">
    <button type="submit">{editing ? "변경 사항 저장" : "새 글 저장"}</button>
    {editing && !post!.draft && (
      <a class="button-link button-link--secondary" href={`/posts/${post!.slug}/`} target="_blank" rel="noreferrer">공개 글 보기</a>
    )}
    <p class="form-status" role="status" aria-live="polite"></p>
  </div>
</form>

<script>
  for (const form of document.querySelectorAll<HTMLFormElement>("form[data-admin-post-form]")) {
    const dateInput = form.querySelector<HTMLInputElement>("[name='publishedAtLocal']");
    const initialIso = form.dataset.initialPublishedAt;
    const initialDate = initialIso ? new Date(initialIso) : new Date();
    if (dateInput && !Number.isNaN(initialDate.getTime())) {
      const localDate = new Date(initialDate.getTime() - initialDate.getTimezoneOffset() * 60_000);
      dateInput.value = localDate.toISOString().slice(0, 16);
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const button = form.querySelector<HTMLButtonElement>("button[type='submit']");
      const status = form.querySelector<HTMLElement>(".form-status");
      const data = new FormData(form);
      const localValue = dateInput?.value;
      if (localValue) data.set("publishedAt", new Date(localValue).toISOString());
      data.delete("publishedAtLocal");

      if (button) button.disabled = true;
      if (status) {
        status.textContent = "저장 중…";
        status.dataset.error = "false";
      }

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: data,
          headers: { Accept: "application/json" },
        });
        const result = await response.json();
        if (!response.ok) throw new Error(result.error ?? "저장하지 못했습니다.");
        window.location.assign(result.location);
      } catch (error) {
        if (status) {
          status.textContent = error instanceof Error ? error.message : "저장하지 못했습니다.";
          status.dataset.error = "true";
        }
        if (button) button.disabled = false;
      }
    });
  }
</script>
