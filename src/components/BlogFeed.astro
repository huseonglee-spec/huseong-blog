---
import type { BlogPost } from "../lib/posts";

import {
  buildCategoryTree,
  categoryHref,
  filterPostsByCategory,
} from "../lib/categories";
import { renderPostMarkdown } from "../lib/markdown";
import { initialVisibleCount, postHref } from "../lib/posts";
import CategorySidebar from "./CategorySidebar.astro";
import NewPostComposer from "./NewPostComposer.astro";
import TableOfContents from "./TableOfContents.astro";

interface Props {
  posts: BlogPost[];
  activeSlug?: string;
  composerCsrfToken?: string;
  composerSubmissionId?: string;
  composerOpen?: boolean;
  withHomeActions?: boolean;
  selectedCategory?: string;
}

const {
  posts,
  activeSlug,
  composerCsrfToken,
  composerSubmissionId,
  composerOpen = false,
  withHomeActions = false,
  selectedCategory,
} = Astro.props;
const categoryTree = buildCategoryTree(posts);
const visiblePosts = filterPostsByCategory(posts, selectedCategory);
const categoryPaths = [...new Set(posts.map((post) => post.data.category))].sort(
  (left, right) => left.localeCompare(right, "ko"),
);
const pageSize = 5;
const activeIndex = activeSlug
  ? visiblePosts.findIndex((post) => post.id === activeSlug)
  : -1;
const visibleCount = Math.min(
  visiblePosts.length,
  initialVisibleCount(activeIndex, pageSize),
);
const renderedPosts = await Promise.all(
  visiblePosts.map(async (post) => ({
    post,
    ...(await renderPostMarkdown(post.bodyMarkdown)),
  })),
);
---

<div class:list={["blog-shell", { "blog-shell--with-home-actions": withHomeActions }]}>
  <CategorySidebar
    tree={categoryTree}
    postCount={posts.length}
    selectedCategory={selectedCategory}
  />
  <main
    class:list={["feed", { "feed--with-home-actions": withHomeActions }]}
    data-feed
    data-active-slug={activeSlug ?? ""}
    data-page-size={pageSize}
  >
  {composerCsrfToken && composerSubmissionId && (
    <NewPostComposer
      csrfToken={composerCsrfToken}
      submissionId={composerSubmissionId}
      open={composerOpen}
      categoryPaths={categoryPaths}
    />
  )}
  {
    renderedPosts.map(({ post, html, headings }, index) => (
      <article
        class="post-container"
        id={`post-${post.id}`}
        data-post={post.id}
        hidden={index >= visibleCount}
      >
        {post.data.thumbnail && (
          <figure class="post-thumbnail">
            <img
              src={post.data.thumbnail}
              alt={post.data.thumbnailAlt ?? ""}
              loading={index === 0 ? "eager" : "lazy"}
            />
          </figure>
        )}

        <header class="post-header">
          <a class="post-category" href={categoryHref(post.data.category)}>
            {post.data.category.replaceAll("/", " / ")}
          </a>
          <h1>
            <a class="post-title-link" href={postHref(post.id)}>
              {post.data.title}
            </a>
          </h1>
          {post.data.subtitle && <p class="post-subtitle">{post.data.subtitle}</p>}
        </header>

        <TableOfContents headings={headings} />

        <div class="post-body" set:html={html} />
      </article>
    ))
  }

  {renderedPosts.length === 0 && (
    <p class="feed-empty">이 카테고리에는 아직 글이 없습니다.</p>
  )}

  <div class="feed-sentinel" data-feed-sentinel aria-hidden="true"></div>
  </main>
</div>

<script>
  const feed = document.querySelector<HTMLElement>("[data-feed]");

  if (feed) {
    const posts = Array.from(
      feed.querySelectorAll<HTMLElement>("[data-post]"),
    );
    const sentinel = feed.querySelector<HTMLElement>("[data-feed-sentinel]");
    const pageSize = Number(feed.dataset.pageSize) || 5;

    const revealNextBatch = () => {
      const hiddenPosts = posts.filter((post) => post.hidden);
      hiddenPosts.slice(0, pageSize).forEach((post) => {
        post.hidden = false;
      });
    };

    if (sentinel && posts.some((post) => post.hidden)) {
      const observer = new IntersectionObserver((entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;

        revealNextBatch();
        if (!posts.some((post) => post.hidden)) observer.disconnect();
      }, { rootMargin: "480px 0px" });

      observer.observe(sentinel);
    }

    const activeSlug = feed.dataset.activeSlug;
    if (activeSlug) {
      requestAnimationFrame(() => {
        document
          .getElementById(`post-${activeSlug}`)
          ?.scrollIntoView({ block: "start" });
      });
    }
  }
</script>
