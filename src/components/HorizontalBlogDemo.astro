---
import type { BlogPost } from "../lib/posts";

import { categoryHref } from "../lib/categories";
import { renderPostMarkdown } from "../lib/markdown";
import { postHref } from "../lib/posts";

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;
const renderedPosts = await Promise.all(
  posts.map(async (post) => ({
    post,
    ...(await renderPostMarkdown(post.bodyMarkdown)),
  })),
);
---

<div class="horizontal-demo" data-horizontal-demo data-post-count={renderedPosts.length}>
  <header class="demo-header">
    <a class="demo-brand" href="/">huseong.com</a>
    <div class="demo-heading">
      <p class="demo-kicker">가로 읽기 실험</p>
      <p class="demo-help">화살표 · 좌우 스와이프 · 키보드 방향키</p>
    </div>
    <a class="demo-exit" href="/">기존 화면</a>
  </header>

  {
    renderedPosts.length > 0 ? (
      <main class="deck-stage" aria-label="게시글 가로 탐색 데모">
        <div class="edge-shade edge-shade--left" aria-hidden="true" />
        <div class="edge-shade edge-shade--right" aria-hidden="true" />

        <button
          class="edge-handle edge-handle--previous"
          type="button"
          aria-label="이전 글"
          aria-controls="horizontal-post-track"
          data-previous-post
          disabled
        >
          <span class="edge-arrow" aria-hidden="true">←</span>
          <span class="edge-copy">
            <span class="edge-direction">이전 글</span>
            <span class="edge-title" data-previous-title>처음입니다</span>
          </span>
        </button>

        <div
          id="horizontal-post-track"
          class="horizontal-track"
          data-horizontal-track
          tabindex="0"
          aria-label="게시글 목록. 좌우로 스크롤할 수 있습니다."
        >
          {renderedPosts.map(({ post, html }, index) => (
            <article
              class="horizontal-post"
              id={`horizontal-post-${post.id}`}
              data-horizontal-post
              data-post-title={post.data.title}
              data-post-index={index}
              aria-label={`${index + 1}번째 글: ${post.data.title}`}
            >
              <div class="post-sheet">
                {post.data.thumbnail && (
                  <figure class="post-cover-image">
                    <img
                      src={post.data.thumbnail}
                      alt={post.data.thumbnailAlt ?? ""}
                      loading={index < 2 ? "eager" : "lazy"}
                    />
                  </figure>
                )}

                <div class="post-sheet-content">
                  <header class="post-header">
                    <a class="post-category" href={categoryHref(post.data.category)}>
                      {post.data.category.replaceAll("/", " / ")}
                    </a>
                    <h1>
                      <a class="post-title-link" href={postHref(post.id)}>
                        {post.data.title}
                      </a>
                    </h1>
                    {post.data.subtitle && <p class="post-subtitle">{post.data.subtitle}</p>}
                  </header>

                  <div class="post-preview post-body" set:html={html} />
                  <a class="post-open" href={postHref(post.id)}>
                    글 전체 읽기 <span aria-hidden="true">↗</span>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>

        <button
          class="edge-handle edge-handle--next"
          type="button"
          aria-label="다음 글"
          aria-controls="horizontal-post-track"
          data-next-post
        >
          <span class="edge-copy">
            <span class="edge-direction">다음 글</span>
            <span class="edge-title" data-next-title>{renderedPosts[1]?.post.data.title ?? "마지막입니다"}</span>
          </span>
          <span class="edge-arrow" aria-hidden="true">→</span>
        </button>
      </main>
    ) : (
      <p class="demo-empty">아직 보여드릴 글이 없습니다.</p>
    )
  }

  {
    renderedPosts.length > 0 && (
      <footer class="deck-status">
        <p class="status-count" aria-live="polite">
          <span data-current-index>01</span>
          <span class="status-divider">/</span>
          <span>{String(renderedPosts.length).padStart(2, "0")}</span>
        </p>
        <div class="status-progress" aria-hidden="true">
          <span data-progress-bar style={`--progress: ${1 / renderedPosts.length}`} />
        </div>
        <p class="status-title" data-current-title>{renderedPosts[0].post.data.title}</p>
      </footer>
    )
  }
</div>

<script>
  const demo = document.querySelector<HTMLElement>("[data-horizontal-demo]");
  const track = demo?.querySelector<HTMLElement>("[data-horizontal-track]");

  if (demo && track) {
    const posts = Array.from(track.querySelectorAll<HTMLElement>("[data-horizontal-post]"));
    const previousButton = demo.querySelector<HTMLButtonElement>("[data-previous-post]");
    const nextButton = demo.querySelector<HTMLButtonElement>("[data-next-post]");
    const previousTitle = demo.querySelector<HTMLElement>("[data-previous-title]");
    const nextTitle = demo.querySelector<HTMLElement>("[data-next-title]");
    const currentIndex = demo.querySelector<HTMLElement>("[data-current-index]");
    const currentTitle = demo.querySelector<HTMLElement>("[data-current-title]");
    const progressBar = demo.querySelector<HTMLElement>("[data-progress-bar]");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let activeIndex = 0;
    let frame = 0;

    const postTitle = (index: number) => posts[index]?.dataset.postTitle ?? "";

    const updateStatus = (index: number) => {
      activeIndex = Math.max(0, Math.min(index, posts.length - 1));
      const hasPrevious = activeIndex > 0;
      const hasNext = activeIndex < posts.length - 1;

      if (previousButton) previousButton.disabled = !hasPrevious;
      if (nextButton) nextButton.disabled = !hasNext;
      if (previousTitle) previousTitle.textContent = hasPrevious ? postTitle(activeIndex - 1) : "처음입니다";
      if (nextTitle) nextTitle.textContent = hasNext ? postTitle(activeIndex + 1) : "마지막입니다";
      if (currentIndex) currentIndex.textContent = String(activeIndex + 1).padStart(2, "0");
      if (currentTitle) currentTitle.textContent = postTitle(activeIndex);
      progressBar?.style.setProperty("--progress", String((activeIndex + 1) / posts.length));
    };

    const goToPost = (index: number) => {
      const target = posts[Math.max(0, Math.min(index, posts.length - 1))];
      target?.scrollIntoView({
        behavior: reducedMotion.matches ? "auto" : "smooth",
        block: "nearest",
        inline: "center",
      });
    };

    const detectCenteredPost = () => {
      cancelAnimationFrame(frame);
      frame = requestAnimationFrame(() => {
        const trackCenter = track.getBoundingClientRect().left + track.clientWidth / 2;
        let nearestIndex = 0;
        let nearestDistance = Number.POSITIVE_INFINITY;

        posts.forEach((post, index) => {
          const rect = post.getBoundingClientRect();
          const distance = Math.abs(rect.left + rect.width / 2 - trackCenter);
          if (distance < nearestDistance) {
            nearestDistance = distance;
            nearestIndex = index;
          }
        });

        if (nearestIndex !== activeIndex) updateStatus(nearestIndex);
      });
    };

    previousButton?.addEventListener("click", () => goToPost(activeIndex - 1));
    nextButton?.addEventListener("click", () => goToPost(activeIndex + 1));
    track.addEventListener("scroll", detectCenteredPost, { passive: true });

    document.addEventListener("keydown", (event) => {
      const target = event.target as HTMLElement | null;
      if (target?.matches("input, textarea, select, [contenteditable='true']")) return;

      if (event.key === "ArrowLeft") {
        event.preventDefault();
        goToPost(activeIndex - 1);
      }
      if (event.key === "ArrowRight") {
        event.preventDefault();
        goToPost(activeIndex + 1);
      }
    });

    updateStatus(0);
  }
</script>

<style>
  .horizontal-demo {
    --header-height: 88px;
    --footer-height: 86px;
    min-height: 100svh;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(95, 73, 51, 0.035) 1px, transparent 1px) center / 25vw 100%,
      radial-gradient(circle at 50% 5%, rgba(255, 255, 255, 0.44), transparent 34rem),
      var(--paper);
  }

  .demo-header {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: var(--header-height);
    padding: 18px clamp(22px, 4vw, 64px);
    border-bottom: 1px solid color-mix(in srgb, var(--line) 66%, transparent);
  }

  .demo-brand,
  .demo-exit {
    color: var(--ink);
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .demo-brand:hover,
  .demo-exit:hover {
    text-decoration: underline;
    text-underline-offset: 0.3em;
  }

  .demo-heading {
    text-align: center;
  }

  .demo-kicker,
  .demo-help {
    margin: 0;
  }

  .demo-kicker {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
  }

  .demo-help {
    margin-top: 0.15rem;
    color: var(--ink-soft);
    font-size: 0.64rem;
    letter-spacing: 0.04em;
  }

  .demo-exit {
    justify-self: end;
    color: var(--ink-soft);
  }

  .deck-stage {
    position: relative;
    height: calc(100svh - var(--header-height) - var(--footer-height));
    min-height: 460px;
  }

  .horizontal-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 100vw;
    gap: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    outline: none;
  }

  .horizontal-track::-webkit-scrollbar {
    display: none;
  }

  .horizontal-track:focus-visible::after {
    position: fixed;
    inset: calc(var(--header-height) + 10px) 50% auto;
    width: min(760px, calc(100vw - 240px));
    height: calc(100svh - var(--header-height) - var(--footer-height) - 20px);
    border: 2px solid color-mix(in srgb, var(--link) 70%, transparent);
    border-radius: 5px;
    pointer-events: none;
    content: "";
    transform: translateX(-50%);
  }

  .horizontal-post {
    display: grid;
    place-items: center;
    width: 100vw;
    height: 100%;
    min-height: 0;
    padding: clamp(18px, 3vh, 32px) max(120px, calc((100vw - 760px) / 2));
    overflow: hidden;
    scroll-snap-align: center;
    scroll-snap-stop: always;
  }

  .post-sheet {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    width: min(760px, 100%);
    height: 100%;
    min-height: 0;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 3px;
    background: color-mix(in srgb, var(--sheet) 94%, transparent);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 18px 60px rgba(71, 52, 32, 0.08);
  }

  .post-sheet:has(.post-cover-image) {
    grid-template-columns: minmax(180px, 0.78fr) minmax(0, 1.22fr);
  }

  .post-cover-image {
    min-width: 0;
    height: 100%;
    margin: 0;
    overflow: hidden;
    border-right: 1px solid var(--line);
  }

  .post-cover-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-sheet-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
    min-height: 0;
    padding: clamp(32px, 5vw, 58px);
    overflow: hidden;
  }

  .post-preview {
    position: relative;
    max-height: min(31vh, 270px);
    margin-top: clamp(1.8rem, 4vh, 2.7rem);
    overflow: hidden;
    color: color-mix(in srgb, var(--ink) 88%, transparent);
    -webkit-mask-image: linear-gradient(to bottom, #000 68%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 68%, transparent 100%);
  }

  .post-preview.post-body {
    font-size: clamp(0.94rem, 1.7vw, 1.04rem);
  }

  .post-preview.post-body > :first-child {
    margin-top: 0;
  }

  .post-open {
    align-self: flex-start;
    margin-top: clamp(1.2rem, 3vh, 2rem);
    padding-bottom: 0.2rem;
    border-bottom: 1px solid color-mix(in srgb, var(--ink-soft) 44%, transparent);
    color: var(--ink-soft);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .post-open:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  .post-open:focus-visible {
    outline: 2px solid var(--link);
    outline-offset: 4px;
  }

  .edge-shade {
    position: absolute;
    z-index: 3;
    top: 0;
    bottom: 0;
    width: clamp(70px, 11vw, 180px);
    pointer-events: none;
  }

  .edge-shade--left {
    left: 0;
    background: linear-gradient(90deg, var(--paper) 22%, transparent);
  }

  .edge-shade--right {
    right: 0;
    background: linear-gradient(-90deg, var(--paper) 22%, transparent);
  }

  .edge-handle {
    position: absolute;
    z-index: 5;
    top: 50%;
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 58px;
    max-width: min(220px, 18vw);
    min-height: 118px;
    padding: 16px 18px;
    border: 1px solid color-mix(in srgb, var(--line) 80%, transparent);
    color: var(--ink);
    background: color-mix(in srgb, var(--sheet) 88%, transparent);
    box-shadow: 0 8px 28px rgba(71, 52, 32, 0.08);
    font: inherit;
    cursor: pointer;
    transform: translateY(-50%);
    transition: background 180ms ease, transform 180ms ease, opacity 180ms ease;
    backdrop-filter: blur(8px);
  }

  .edge-handle--previous {
    left: 0;
    justify-content: flex-start;
    border-left: 0;
    border-radius: 0 3px 3px 0;
  }

  .edge-handle--next {
    right: 0;
    justify-content: flex-end;
    border-right: 0;
    border-radius: 3px 0 0 3px;
    text-align: right;
  }

  .edge-handle:hover:not(:disabled) {
    background: color-mix(in srgb, var(--sheet) 98%, transparent);
  }

  .edge-handle--previous:hover:not(:disabled) {
    transform: translate(5px, -50%);
  }

  .edge-handle--next:hover:not(:disabled) {
    transform: translate(-5px, -50%);
  }

  .edge-handle:focus-visible {
    outline: 2px solid var(--link);
    outline-offset: 4px;
  }

  .edge-handle:disabled {
    opacity: 0.24;
    cursor: default;
  }

  .edge-arrow {
    flex: none;
    font-size: 1.35rem;
    line-height: 1;
  }

  .edge-copy {
    display: grid;
    width: 0;
    overflow: hidden;
    opacity: 0;
    transition: width 220ms ease, opacity 180ms ease;
  }

  .edge-handle:hover:not(:disabled) .edge-copy,
  .edge-handle:focus-visible .edge-copy {
    width: min(132px, 11vw);
    opacity: 1;
  }

  .edge-direction {
    color: var(--ink-soft);
    font-size: 0.61rem;
    letter-spacing: 0.11em;
  }

  .edge-title {
    display: -webkit-box;
    margin-top: 0.35rem;
    overflow: hidden;
    font-size: 0.72rem;
    font-weight: 650;
    line-height: 1.55;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .deck-status {
    position: relative;
    z-index: 8;
    display: grid;
    grid-template-columns: auto minmax(120px, 340px) minmax(0, 1fr);
    align-items: center;
    gap: clamp(16px, 3vw, 34px);
    height: var(--footer-height);
    padding: 16px clamp(22px, 4vw, 64px);
    border-top: 1px solid color-mix(in srgb, var(--line) 66%, transparent);
    background: color-mix(in srgb, var(--paper) 86%, transparent);
    backdrop-filter: blur(8px);
  }

  .status-count,
  .status-title {
    margin: 0;
  }

  .status-count {
    display: flex;
    gap: 0.45rem;
    min-width: 4.9rem;
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.1em;
  }

  .status-divider {
    color: color-mix(in srgb, var(--ink-soft) 54%, transparent);
  }

  .status-progress {
    height: 1px;
    overflow: hidden;
    background: color-mix(in srgb, var(--ink-soft) 24%, transparent);
  }

  .status-progress span {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--ink);
    transform: scaleX(var(--progress));
    transform-origin: left center;
    transition: transform 280ms ease;
  }

  .status-title {
    overflow: hidden;
    color: var(--ink-soft);
    font-size: 0.7rem;
    text-align: right;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .demo-empty {
    width: min(100% - 40px, 760px);
    margin: 20vh auto 0;
    text-align: center;
  }

  @media (max-width: 760px) {
    .horizontal-demo {
      --header-height: 72px;
      --footer-height: 74px;
    }

    .demo-header {
      grid-template-columns: 1fr auto;
      padding: 14px 18px;
    }

    .demo-heading {
      display: none;
    }

    .demo-brand,
    .demo-exit {
      font-size: 0.72rem;
    }

    .horizontal-post {
      padding: 14px 16px 10px;
    }

    .horizontal-track:focus-visible::after {
      width: calc(100vw - 32px);
    }

    .post-sheet-content {
      padding: 30px 22px 34px;
    }

    .post-sheet:has(.post-cover-image) {
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: minmax(100px, 25%) minmax(0, 1fr);
    }

    .post-cover-image {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .post-preview {
      max-height: min(36vh, 280px);
      margin-top: 1.6rem;
    }

    .edge-shade {
      display: none;
    }

    .edge-handle {
      z-index: 12;
      top: auto;
      bottom: calc(var(--footer-height) * -1 + 14px);
      min-width: 42px;
      min-height: 42px;
      padding: 10px 12px;
      border: 1px solid var(--line);
      border-radius: 50%;
      background: var(--sheet);
      transform: none;
      backdrop-filter: none;
    }

    .edge-handle--previous {
      left: 18px;
    }

    .edge-handle--next {
      right: 18px;
    }

    .edge-handle--previous:hover:not(:disabled),
    .edge-handle--next:hover:not(:disabled) {
      transform: none;
    }

    .edge-copy {
      display: none;
    }

    .edge-arrow {
      font-size: 1rem;
    }

    .deck-status {
      grid-template-columns: 64px minmax(80px, 1fr) 64px;
      gap: 12px;
      padding: 14px 70px;
    }

    .status-count {
      min-width: 0;
      font-size: 0.65rem;
    }

    .status-title {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .edge-handle,
    .edge-copy,
    .status-progress span {
      transition: none;
    }

    .horizontal-track {
      scroll-behavior: auto;
    }
  }
</style>
