---
import type { CategoryNode } from "../lib/categories";
import { categoryHref } from "../lib/categories";
import CategoryBranch from "./CategoryBranch.astro";

interface Props {
  nodes: CategoryNode[];
  selectedCategory?: string;
}

const { nodes, selectedCategory } = Astro.props;
---

<ul class="category-tree__list">
  {
    nodes.map((node) => (
      <li class="category-tree__item">
        <a
          class:list={["category-tree__link", { "is-active": selectedCategory === node.path }]}
          href={categoryHref(node.path)}
          aria-current={selectedCategory === node.path ? "page" : undefined}
        >
          <span>{node.name}</span>
          <span class="category-tree__count">{node.count}</span>
        </a>
        {node.children.length > 0 && (
          <CategoryBranch nodes={node.children} selectedCategory={selectedCategory} />
        )}
      </li>
    ))
  }
</ul>
