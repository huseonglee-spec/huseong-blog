---
import { POST_VISIBILITIES, visibilityLabel } from "../lib/visibility";

interface Props {
  csrfToken: string;
  submissionId: string;
  open?: boolean;
  categoryPaths?: string[];
}

const { csrfToken, submissionId, open = false, categoryPaths = [] } = Astro.props;
---

<article
  class="post-container new-post-composer"
  id="new-post"
  data-new-post-composer
  hidden={!open}
>
  <form action="/api/posts/" method="post" data-new-post-form>
    <input type="hidden" name="csrfToken" value={csrfToken} />
    <input type="hidden" name="submissionId" value={submissionId} />

    <label class="visually-hidden" for="new-post-title">제목</label>
    <input
      class="new-post-title"
      id="new-post-title"
      name="title"
      type="text"
      maxlength="200"
      placeholder="제목"
      autocomplete="off"
      required
    />

    <label class="visually-hidden" for="new-post-category">카테고리</label>
    <input
      class="new-post-category"
      id="new-post-category"
      name="category"
      type="text"
      maxlength="200"
      list="post-category-options"
      placeholder="카테고리 (예: 기술 / AI)"
      autocomplete="off"
    />
    <datalist id="post-category-options">
      {categoryPaths.map((path) => <option value={path} />)}
    </datalist>

    <label class="visually-hidden" for="new-post-visibility">공개 범위</label>
    <select
      class="new-post-visibility"
      id="new-post-visibility"
      name="visibility"
    >
      {POST_VISIBILITIES.map((visibility) => (
        <option value={visibility}>{visibilityLabel(visibility)}</option>
      ))}
    </select>

    <label class="visually-hidden" for="new-post-body">본문</label>
    <textarea
      class="new-post-body"
      id="new-post-body"
      name="bodyMarkdown"
      maxlength="170000"
      placeholder="내용을 작성하세요"
      required
    ></textarea>

    <footer class="new-post-footer">
      <p class="new-post-status" data-new-post-status aria-live="polite"></p>
      <div class="new-post-buttons">
        <button type="button" class="text-button" data-cancel-composer>취소</button>
        <button type="submit" class="publish-button">게시</button>
      </div>
    </footer>
  </form>
</article>

<script>
  const composer = document.querySelector<HTMLElement>("[data-new-post-composer]");
  const form = composer?.querySelector<HTMLFormElement>("[data-new-post-form]");
  const body = composer?.querySelector<HTMLTextAreaElement>("[name=bodyMarkdown]");
  const status = composer?.querySelector<HTMLElement>("[data-new-post-status]");
  const submitButton = form?.querySelector<HTMLButtonElement>("[type=submit]");
  const cancelButton = form?.querySelector<HTMLButtonElement>("[data-cancel-composer]");
  const composerOpenButton = document.querySelector<HTMLElement>("[data-open-composer]");
  let submitting = false;

  const resizeBody = () => {
    if (!body) return;
    body.style.height = "auto";
    body.style.height = `${Math.max(body.scrollHeight, window.innerHeight * 0.42)}px`;
  };

  body?.addEventListener("input", resizeBody);
  resizeBody();

  cancelButton?.addEventListener("click", () => {
    if (submitting || !composer) return;
    composer.hidden = true;
    composerOpenButton?.setAttribute("aria-expanded", "false");
    history.replaceState(null, "", "/");
    composerOpenButton?.focus();
  });

  form?.addEventListener("keydown", (event) => {
    if (!submitting && (event.metaKey || event.ctrlKey) && event.key === "Enter") {
      event.preventDefault();
      form.requestSubmit();
    }
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (submitting || !submitButton || !status) return;

    submitting = true;
    submitButton.disabled = true;
    if (cancelButton) cancelButton.disabled = true;
    status.dataset.error = "false";
    status.textContent = "게시 중…";

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });
      const result = await response.json() as { error?: string; location?: string };
      if (!response.ok || !result.location) {
        throw new Error(result.error ?? "글을 게시하지 못했습니다.");
      }
      window.location.assign(result.location);
    } catch (error) {
      status.dataset.error = "true";
      status.textContent = error instanceof Error ? error.message : "글을 게시하지 못했습니다.";
      submitting = false;
      submitButton.disabled = false;
      if (cancelButton) cancelButton.disabled = false;
    }
  });
</script>

<style>
  .new-post-composer { scroll-margin-top: 5.5rem; }
  .new-post-composer form { display: grid; }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .new-post-title,
  .new-post-category,
  .new-post-visibility,
  .new-post-body {
    width: 100%;
    padding: 0;
    border: 0;
    outline: 0;
    color: var(--ink);
    background: transparent;
    font: inherit;
  }
  .new-post-title:focus-visible,
  .new-post-category:focus-visible,
  .new-post-visibility:focus-visible,
  .new-post-body:focus-visible {
    box-shadow: inset 0 -2px 0 color-mix(in srgb, var(--link) 58%, transparent);
  }
  .new-post-title {
    margin-bottom: 2.4rem;
    font-size: clamp(1.72rem, 5vw, 2.55rem);
    font-weight: 650;
    line-height: 1.42;
    letter-spacing: -0.035em;
  }
  .new-post-category {
    margin: -1.3rem 0 0.75rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.82rem;
  }
  .new-post-visibility {
    justify-self: start;
    margin-bottom: 2rem;
    color: var(--ink-soft);
    font-size: 0.82rem;
  }
  .new-post-body {
    min-height: 42vh;
    resize: none;
    font-size: clamp(1rem, 2.15vw, 1.08rem);
    line-height: 1.9;
  }
  .new-post-title::placeholder,
  .new-post-category::placeholder,
  .new-post-body::placeholder { color: color-mix(in srgb, var(--ink-soft) 58%, transparent); }
  .new-post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }
  .new-post-status {
    min-height: 1.5em;
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.8rem;
  }
  .new-post-status[data-error="true"] { color: #9a3e2e; }
  .new-post-buttons { display: flex; align-items: center; gap: 0.8rem; }
  .new-post-buttons button {
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--ink);
    border-radius: 2px;
    font: inherit;
    font-size: 0.82rem;
    cursor: pointer;
  }
  .text-button { color: var(--ink); background: transparent; }
  .publish-button { color: var(--sheet); background: var(--ink); }
  .new-post-buttons button:disabled { cursor: wait; opacity: 0.6; }

  @media (max-width: 560px) {
    .new-post-footer { align-items: flex-end; flex-direction: column; }
  }
</style>
